# ─── App ──────────────────────────────────────────────────────
APP_ENV=production
# Generate: python -c "import os,binascii; print(binascii.hexlify(os.urandom(32)).decode())"
SECRET_KEY=

# ─── Database ─────────────────────────────────────────────────
# Railway PostgreSQL: copy the DATABASE_URL from the Railway service variables panel.
# Replace "postgresql://" with "postgresql+asyncpg://" for async SQLAlchemy.
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ─── Redis ────────────────────────────────────────────────────
# Railway Redis: copy REDIS_URL from the Redis service variables panel.
REDIS_URL=redis://default:password@host:6379

# ─── Plaid ────────────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
# Use "sandbox" for testing, "production" for live
PLAID_ENV=sandbox
# Set to your Railway backend URL once deployed
PLAID_WEBHOOK_URL=https://your-app.railway.app/api/v1/plaid/webhook

# ─── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Encryption ───────────────────────────────────────────────
# 64 hex characters = 32 bytes for AES-256-GCM
# Generate: python -c "import os,binascii; print(binascii.hexlify(os.urandom(32)).decode())"
# WARNING: rotating this key invalidates all stored Plaid access tokens
ENCRYPTION_KEY=

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no spaces)
# Add your Vercel frontend URL here
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ─── Approval Settings ────────────────────────────────────────
INTENT_EXPIRY_HOURS=48
REAUTH_THRESHOLD_DOLLARS=0.01
